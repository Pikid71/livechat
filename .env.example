# Black Hole Chat V2 - Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Connection (Atlas recommended)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# Admin/Owner Configuration
ADMIN_PASSWORD=your_secure_admin_password
OWNER_USERNAME=your_owner_username

# File Upload Settings
MAX_FILE_SIZE=52428800
UPLOAD_PATH=./uploads

# AI Integration - OpenRouter
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_api_key_here

# Image Generation - Stable Horde (primary provider)
STABLE_HORDE_API_KEY=your_stable_horde_api_key_here

# Image Generation - DeAPI.ai (fallback provider)
DEAPI_API_KEY=your_deapi_api_key_here
